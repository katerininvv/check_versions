# ─── Update Tracker · переменные окружения ───────────────────────────────────
# Скопируйте этот файл в .env и заполните значения:  cp .env.example .env

# ОБЯЗАТЕЛЬНО. Мастер-ключ для подписи сессий и шифрования секретов.
# Сгенерируйте свой:  openssl rand -hex 32
SECRET_KEY=

# Учётные данные администратора при ПЕРВОМ запуске.
# Если ADMIN_PASSWORD пуст — пароль сгенерируется и будет напечатан в логах.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=

# Порт HTTPS наружу.
HTTPS_PORT=18237

# Часовой пояс расписания рассылки.
TZ=Europe/Moscow

# ─── Сид-секреты (можно оставить пустыми и заполнить позже в UI → Настройки) ──
# Токен Telegram-бота (от @BotFather).
TELEGRAM_BOT_TOKEN=
# chat_id личного чата. Можно оставить пустым и определить кнопкой в Настройках.
TELEGRAM_CHAT_ID=
# Ключ DeepL API (бесплатный оканчивается на :fx).
DEEPL_API_KEY=
# Токен GitHub (необязательно — повышает лимит при получении release notes).
GITHUB_TOKEN=

# ─── Тонкая настройка (необязательно) ────────────────────────────────────────
# Времена ежедневных проверок (формат HH:MM), можно менять в UI.
# Сообщение приходит только если что-то обновилось.
CHECK_TIME_MORNING=09:00
CHECK_TIME_NOON=13:00
CHECK_TIME_EVENING=19:00

# SubjectAltName для самоподписанного сертификата. Добавьте сюда IP вашего сервера,
# чтобы сертификат был валиден для него, например: IP:203.0.113.10,IP:127.0.0.1,DNS:localhost
TLS_SAN=IP:127.0.0.1,DNS:localhost

# Установите false ТОЛЬКО если временно открываете интерфейс по http (без TLS).
SESSION_COOKIE_SECURE=true
